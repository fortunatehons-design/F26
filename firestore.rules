rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "fortunatehons@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidPackage(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.city is string && data.city.size() > 0 &&
             data.price is number && data.price > 0 &&
             data.availability is number;
    }

    function isValidOrder(data) {
      return data.packageId is string &&
             data.quantity is number && data.quantity > 0 &&
             data.totalAmount is number && data.totalAmount > 0 &&
             data.status in ['pending_wire', 'paid', 'cancelled'] &&
             data.userEmail is string &&
             data.userId == request.auth.uid;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin() || (isOwner(resource.data.userId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['wireTransferScreenshot', 'paymentConfirmedByUser']));
    }

    match /bankAccounts/{accountId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /knowledgeBase/{entryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
